//@version=5
indicator("Live Decision Tool", overlay=true, precision=2, max_labels_count=500)

// Flash Point Pro v0.8，依作者提供公式重建。
flashPoint() =>
    float typicalPrice = (2 * close + high + low) / 4
    float periodLowest = ta.lowest(low, 5)
    float periodHighest = ta.highest(high, 4)
    float priceRange = periodHighest - periodLowest
    float stochVal = priceRange == 0 ? 0 : ((typicalPrice - periodLowest) / priceRange) * 100
    float c1 = ta.ema(stochVal, 4)
    float slowBase = 0.667 * nz(c1[1]) + 0.333 * c1
    float c2 = ta.ema(slowBase, 2)
    bool crossUp = ta.crossover(c1, c2)
    bool crossDown = ta.crossunder(c1, c2)
    [c1, c2, crossUp, crossDown]

addReason(string base, string reason) =>
    reason == "" ? base : base == "" ? reason : base + " + " + reason

formatLevel(float value) =>
    str.tostring(value, "#.##")

// 顯示設定
showTable = input.bool(true, "顯示狀態表")
tableLocation = input.string("右上", "狀態表位置", options=["右上", "右下", "左上", "左下", "中上", "中下"])
tableSize = input.string("一般", "狀態表大小", options=["極小", "小", "一般", "大", "特大"])
showLiveLabel = input.bool(true, "顯示最新提示標籤")
showMarkers = input.bool(true, "顯示進場/減倉/出場標記")
positionSide = input.string("空倉", "目前持倉", options=["空倉", "多單", "空單"])

// 幣種偵測
symbolText = str.upper(syminfo.tickerid)
isBTC = str.contains(symbolText, "BTCUSDC")
isETH = str.contains(symbolText, "ETHUSDC")
isSOL = str.contains(symbolText, "SOLUSDC")
supported = isBTC or isETH or isSOL
target = isBTC ? "BTCUSDC" : isETH ? "ETHUSDC" : isSOL ? "SOLUSDC" : syminfo.ticker
labelSymbol = isBTC ? "BTC" : isETH ? "ETH" : isSOL ? "SOL" : syminfo.ticker

// 來自 6 個月研究基準的第一版參數。
mainTf = isBTC ? "5" : isETH ? "10" : isSOL ? "10" : timeframe.period
earlyTf = isBTC ? "2" : isETH ? "2" : isSOL ? "3" : timeframe.period
filterTf = isBTC ? "15" : mainTf

longWatchC1 = isSOL ? 50.0 : 45.0
longReadyC1 = isSOL ? 45.0 : 35.0
longEnterC1 = isSOL ? 45.0 : 40.0
shortWatchC1 = 55.0
shortReadyC1 = 65.0
shortEnterC1 = 60.0
readyScoreNeed = 3
enterScoreNeed = 4

[mainC1, mainC2, mainCrossUp, mainCrossDown] = request.security(syminfo.tickerid, mainTf, flashPoint(), barmerge.gaps_off, barmerge.lookahead_off)
[earlyC1, earlyC2, earlyCrossUp, earlyCrossDown] = request.security(syminfo.tickerid, earlyTf, flashPoint(), barmerge.gaps_off, barmerge.lookahead_off)
[filterC1, filterC2, filterCrossUp, filterCrossDown] = request.security(syminfo.tickerid, filterTf, flashPoint(), barmerge.gaps_off, barmerge.lookahead_off)

// 這裡的分數刻意比嚴格回測策略寬，目標是即時提示反轉。
bullScore = 0
bullScore += mainC1 <= longWatchC1 ? 1 : 0
bullScore += mainC1 <= longReadyC1 ? 1 : 0
bullScore += mainC1 > mainC2 ? 1 : 0
bullScore += mainC1 <= mainC2 and mainC2 - mainC1 <= 5 ? 1 : 0
bullScore += mainCrossUp ? 2 : 0
bullScore += earlyC1 > earlyC2 or earlyCrossUp ? 1 : 0

bearScore = 0
bearScore += mainC1 >= shortWatchC1 ? 1 : 0
bearScore += mainC1 >= shortReadyC1 ? 1 : 0
bearScore += mainC1 < mainC2 ? 1 : 0
bearScore += mainC1 >= mainC2 and mainC1 - mainC2 <= 5 ? 1 : 0
bearScore += mainCrossDown ? 2 : 0
bearScore += earlyC1 < earlyC2 or earlyCrossDown ? 1 : 0

// BTC 使用 15m 當反向壓力過濾；ETH/SOL 第一版先用主週期。
longVeto = isBTC and filterC1 < filterC2 and filterC1 > 60
shortVeto = isBTC and filterC1 > filterC2 and filterC1 < 40

longWatch = supported and mainC1 <= longWatchC1 and not longVeto
shortWatch = supported and mainC1 >= shortWatchC1 and not shortVeto
longReady = supported and mainC1 <= longReadyC1 and bullScore >= readyScoreNeed and not longVeto
shortReady = supported and mainC1 >= shortReadyC1 and bearScore >= readyScoreNeed and not shortVeto
longEnter = supported and mainCrossUp and mainC1 <= longEnterC1 and bullScore >= enterScoreNeed and not longVeto
shortEnter = supported and mainCrossDown and mainC1 >= shortEnterC1 and bearScore >= enterScoreNeed and not shortVeto

longReason = ""
longReason := addReason(longReason, mainCrossUp ? "向上交叉" : "")
longReason := addReason(longReason, mainC1 <= longReadyC1 ? "C1 低位" : mainC1 <= longWatchC1 ? "C1 接近低位" : "")
longReason := addReason(longReason, mainC1 > mainC2 ? "C1 高於 C2" : mainC2 - mainC1 <= 5 ? "C1/C2 收斂" : "")
longReason := addReason(longReason, earlyC1 > earlyC2 or earlyCrossUp ? "早期週期同向" : "")
longReason := addReason(longReason, "多方分數 " + str.tostring(bullScore))

shortReason = ""
shortReason := addReason(shortReason, mainCrossDown ? "向下交叉" : "")
shortReason := addReason(shortReason, mainC1 >= shortReadyC1 ? "C1 高位" : mainC1 >= shortWatchC1 ? "C1 接近高位" : "")
shortReason := addReason(shortReason, mainC1 < mainC2 ? "C1 低於 C2" : mainC1 - mainC2 <= 5 ? "C1/C2 收斂" : "")
shortReason := addReason(shortReason, earlyC1 < earlyC2 or earlyCrossDown ? "早期週期同向" : "")
shortReason := addReason(shortReason, "空方分數 " + str.tostring(bearScore))

state = "等待"
side = ""
reason = supported ? "尚無反轉結構" : "沒有調校參數"

if not supported
    state := "未支援"
    side := ""
    reason := "沒有調校參數"
else if positionSide == "多單"
    side := "多單"
    if mainCrossDown and bearScore >= 4
        state := "出場"
        reason := shortReason
    else if bearScore >= 3 or mainC1 < mainC2
        state := "減倉"
        reason := shortReason
    else
        state := "續抱"
        reason := addReason(addReason("", "趨勢仍可"), addReason("無強空方壓力", "多方分數 " + str.tostring(bullScore)))
else if positionSide == "空單"
    side := "空單"
    if mainCrossUp and bullScore >= 4
        state := "出場"
        reason := longReason
    else if bullScore >= 3 or mainC1 > mainC2
        state := "減倉"
        reason := longReason
    else
        state := "續抱"
        reason := addReason(addReason("", "趨勢仍可"), addReason("無強多方壓力", "空方分數 " + str.tostring(bearScore)))
else
    if longEnter
        state := "進場"
        side := "多單"
        reason := longReason
    else if shortEnter
        state := "進場"
        side := "空單"
        reason := shortReason
    else if longReady and (not shortReady or bullScore >= bearScore)
        state := "準備"
        side := "多單"
        reason := longReason
    else if shortReady
        state := "準備"
        side := "空單"
        reason := shortReason
    else if longWatch and (not shortWatch or bullScore >= bearScore)
        state := "觀察"
        side := "多單"
        reason := longReason
    else if shortWatch
        state := "觀察"
        side := "空單"
        reason := shortReason

signalText = supported ? labelSymbol + (side == "" ? " " : " " + side + " ") + state + "：" + reason : target + " 未支援：沒有調校參數"
targetText = supported ? "目標：" + target + " 已套用參數 | 主週期 " + mainTf + "m | 早期週期 " + earlyTf + "m" : "目標：" + target + " 未支援"

stateColor = state == "進場" or state == "續抱" ? color.rgb(30, 180, 95) :
     state == "準備" or state == "觀察" ? color.rgb(240, 185, 11) :
     state == "減倉" ? color.rgb(245, 166, 35) :
     state == "出場" or state == "未支援" ? color.rgb(230, 70, 70) : color.rgb(120, 130, 145)

markerBelow = side == "多單"
markerAbove = side == "空單"
plotshape(showMarkers and state == "進場" and markerBelow, title="多單進場", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.small, text="進")
plotshape(showMarkers and state == "進場" and markerAbove, title="空單進場", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, text="進")
plotshape(showMarkers and state == "減倉" and markerBelow, title="多單減倉", style=shape.circle, location=location.abovebar, color=color.orange, size=size.tiny, text="減")
plotshape(showMarkers and state == "減倉" and markerAbove, title="空單減倉", style=shape.circle, location=location.belowbar, color=color.orange, size=size.tiny, text="減")
plotshape(showMarkers and state == "出場" and markerBelow, title="多單出場", style=shape.xcross, location=location.abovebar, color=color.red, size=size.small, text="出")
plotshape(showMarkers and state == "出場" and markerAbove, title="空單出場", style=shape.xcross, location=location.belowbar, color=color.lime, size=size.small, text="出")

var label liveLabel = na
if showLiveLabel and barstate.islast
    label.delete(liveLabel)
    y = side == "空單" ? high : low
    labelStyle = side == "空單" ? label.style_label_down : label.style_label_up
    liveLabel := label.new(bar_index, y, signalText, style=labelStyle, color=color.new(stateColor, 5), textcolor=color.white, size=size.small)

tablePosition = tableLocation == "右上" ? position.top_right :
     tableLocation == "右下" ? position.bottom_right :
     tableLocation == "左上" ? position.top_left :
     tableLocation == "左下" ? position.bottom_left :
     tableLocation == "中上" ? position.top_center : position.bottom_center

tableTextSize = tableSize == "極小" ? size.tiny :
     tableSize == "小" ? size.small :
     tableSize == "大" ? size.large :
     tableSize == "特大" ? size.huge : size.normal

var table statusTable = table.new(tablePosition, 2, 7, border_width=1)
if showTable and barstate.islast
    table.cell(statusTable, 0, 0, "Live Decision Tool", text_color=color.white, bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 1, 0, state, text_color=color.white, bgcolor=stateColor, text_size=tableTextSize)
    table.cell(statusTable, 0, 1, "目標", text_color=color.rgb(190, 195, 205), bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 1, 1, targetText, text_color=color.white, bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 0, 2, "提示", text_color=color.rgb(190, 195, 205), bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 1, 2, signalText, text_color=color.white, bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 0, 3, "C1 / C2", text_color=color.rgb(190, 195, 205), bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 1, 3, formatLevel(mainC1) + " / " + formatLevel(mainC2), text_color=color.white, bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 0, 4, "分數", text_color=color.rgb(190, 195, 205), bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 1, 4, "多 " + str.tostring(bullScore) + " | 空 " + str.tostring(bearScore), text_color=color.white, bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 0, 5, "持倉", text_color=color.rgb(190, 195, 205), bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 1, 5, "手動：" + positionSide, text_color=color.white, bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 0, 6, "即時提醒", text_color=color.rgb(190, 195, 205), bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)
    table.cell(statusTable, 1, 6, "盤中狀態可能在收線前改變", text_color=color.white, bgcolor=color.rgb(20, 24, 32), text_size=tableTextSize)

alertcondition(state == "進場" and side == "多單", "Flash Point 多單進場", "Flash Point 多單進場")
alertcondition(state == "進場" and side == "空單", "Flash Point 空單進場", "Flash Point 空單進場")
alertcondition(state == "減倉", "Flash Point 減倉", "Flash Point 減倉")
alertcondition(state == "出場", "Flash Point 出場", "Flash Point 出場")
