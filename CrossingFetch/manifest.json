{
  "manifest_version": 3,
  "name": "CrossingFetch",
  "version": "0.1.0",
  "description": "Records TradingView K-line data and visible Flash Point Pro values for later algorithm analysis.",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://tw.tradingview.com/*",
    "https://www.tradingview.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://tw.tradingview.com/*",
        "https://www.tradingview.com/*"
      ],
      "js": [
        "injected.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://tw.tradingview.com/*",
        "https://www.tradingview.com/*"
      ],
      "js": [
        "core.js",
        "live-signal.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start"
    }
  ]
}
